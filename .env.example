# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_api_key_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Single shared password that gates access to the entire app.
# For local development, set this to something simple like "dev".
# For production, use a strong random password.
AUTH_PASSWORD=your-shared-password-here

# Secret used to sign the auth cookie. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER reuse this value across environments.
AUTH_SECRET=random-string-for-cookie-signing-min-32-chars
